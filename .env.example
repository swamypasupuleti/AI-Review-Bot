# Copy to .env and fill in real values. Never commit .env.

GITHUB_WEBHOOK_SECRET=replace-with-a-long-random-string

# Fine-grained PAT with: Pull requests: Read & write, Contents: Read.
GITHUB_TOKEN=ghp_xxx

OPENAI_API_KEY=sk-xxx
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# GitHub login that triggers the bot when assigned to a PR (case-insensitive).
BOT_USERNAME=review-bot-user

# Where ChromaDB persists per-repo indexes.
INDEX_DIR=./indexes

# Per-section character budgets fed to the LLM prompt.
DIFF_BUDGET=30000
RAG_BUDGET=18000

# Top-k similar chunks pulled from the vector store per changed file.
RAG_TOP_K=8

# Chunking parameters for the indexer.
CHUNK_SIZE=1000
CHUNK_OVERLAP=100
